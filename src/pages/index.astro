---
import BaseLayout from '../layouts/BaseLayout.astro';
import NoiseOverlay from '../components/ui/NoiseOverlay.astro';
import Shell from '../components/layout/Shell.astro';
import Navigation from '../components/layout/Navigation.astro';
import MobileMenu from '../components/layout/MobileMenu.astro';
import Hero from '../components/sections/Hero.astro';
import Download from '../components/sections/Download.astro';
import Bento from '../components/sections/Bento.astro';
import Features from '../components/sections/Features.astro';
import Methodology from '../components/sections/Methodology.astro';
import Changelog from '../components/sections/Changelog.astro';
import Cta from '../components/sections/Cta.astro';
import Footer from '../components/layout/Footer.astro';
import '../styles/shared.css';
import '../styles/responsive.css';
---

<BaseLayout
  title="OpenJunior — Asistente de IA para Todos"
  description="OpenJunior es un asistente de inteligencia artificial para cualquier persona. Catálogo MCP, 1000+ integraciones con servicios, skills reutilizables. Descarga gratis."
  keywords="OpenJunior, asistente de IA, inteligencia artificial, MCP, integraciones, Composio, skills, Google, AI para todos"
>
  <NoiseOverlay />
  <Shell>
    <Navigation />
    <MobileMenu />
    <Hero />
    <Download />
    <Bento />
    <Features />
    <Methodology />
    <Changelog />
    <Cta />
    <Footer />
  </Shell>

  <script>
    const menuBtn = document.getElementById('mobile-menu-btn');
    const menuClose = document.getElementById('mobile-menu-close');
    const mobileMenu = document.getElementById('mobile-menu');

    function toggleMenu() {
      mobileMenu.classList.toggle('open');
      document.body.style.overflow = mobileMenu.classList.contains('open') ? 'hidden' : '';
    }

    if (menuBtn && mobileMenu) {
      menuBtn.addEventListener('click', toggleMenu);
      if (menuClose) menuClose.addEventListener('click', toggleMenu);

      mobileMenu.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', toggleMenu);
      });
    }

    const revealElements = document.querySelectorAll('.reveal');

    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            revealObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );

    revealElements.forEach((el) => revealObserver.observe(el));
  </script>
</BaseLayout>
