---
import BaseLayout from '../layouts/BaseLayout.astro';
import NoiseOverlay from '../components/ui/NoiseOverlay.astro';
import Shell from '../components/layout/Shell.astro';
import Navigation from '../components/layout/Navigation.astro';
import MobileMenu from '../components/layout/MobileMenu.astro';
import Footer from '../components/layout/Footer.astro';
import '../styles/shared.css';
import '../styles/responsive.css';
---

<BaseLayout
  title="Sobre Glenker — La interfaz visual para agentes de código AI"
  description="Glenker es una interfaz rica para agentes de código AI, fork de OpenChamber. Catálogo de MCPs, skills reutilizables, multi-dispositivo y acceso remoto. Open source y gratis."
  canonical="https://glenker.vercel.app/about"
  keywords="Glenker, agente de código, OpenCode, OpenChamber, MCP, skills, fork, xenoxf, desarrollo"
>
  <NoiseOverlay />
  <Navigation />
  <MobileMenu />
  <Shell>
    <section class="about-hero">
      <span class="section-label">// Sobre Glenker</span>
      <h1 class="about-title">La interfaz visual para <span class="gradient-text">agentes de código</span></h1>
      <p class="about-desc">
        Glenker nació de una molestia simple: la experiencia de los agentes de código estaba guardada para quienes
        viven en la terminal. Quisimos una interfaz rica que cualquiera abra y use el mismo día, sin renunciar a
        todo el poder de la IA para programar.
      </p>
    </section>

    <section class="about-content">
      <div class="about-grid">
        <div class="about-text">
          <h2>¿Qué es Glenker?</h2>
          <p>
            Es una interfaz rica para agentes de código AI. Revisas diffs, gestionas agentes, corres servidores y
            mantienes el panorama completo mientras la IA programa por ti — desde el navegador, el escritorio o tu
            celular. Glenker nace como un fork de OpenChamber con una visión distinta: llevar los agentes de código
            al usuario común, no solo al dev.
          </p>
          <p>
            Trae un catálogo de MCPs donde instalas herramientas y APIs con un clic, un sistema de skills reutilizables
            y mejoras de UX pensadas para ver y entender, no para adivinar comandos. Y esto es solo el principio.
          </p>
          <h2>Características principales</h2>
          <ul>
          <li><strong>Chat ramificable:</strong> Línea de tiempo con <code>/undo</code>, <code>/redo</code> y forks con un clic desde cualquier turno.</li>
          <li><strong>Tool UIs inteligentes:</strong> Diffs, operaciones de archivo, permisos y progreso de tareas largas, visualizados.</li>
          <li><strong>Multi-agente:</strong> Ejecuciones desde un solo prompt con worktrees aislados.</li>
          <li><strong>Git y GitHub nativos:</strong> Identidades, commits, PRs, checks y acciones de merge; sesiones desde issues y PRs.</li>
          <li><strong>MCP Registry:</strong> Catálogo completo de MCPs con servidores built-in, buscador y proxy.</li>
          <li><strong>Skills reutilizables:</strong> Creas, instalas y compartes automatizaciones entre proyectos.</li>
          <li><strong>Multi-dispositivo:</strong> Escritorio, web, PWA y móvil. Misma sesión en todos lados, con acceso remoto por túneles.</li>
          <li><strong>Personalización:</strong> 18+ temas, temas propios en JSON, atajos configurables e integraciones Google.</li>
          </ul>
        </div>
        <aside class="about-sidebar">
          <div class="about-card">
            <h3>Detalles</h3>
            <ul>
              <li><strong>Plataformas:</strong> macOS, Windows, Linux, Web &amp; PWA, Móvil</li>
              <li><strong>Precio:</strong> Gratuito </li>
            </ul>
          </div>
          <div class="about-card">
            <h3>Creador</h3>
            <ul>
              <li><strong>Jesús Adrian Camacho Casierra</strong> (aka <a href="https://github.com/xenoxf" target="_blank" rel="noopener noreferrer">xenoxf</a>)</li>
              <li>Dev fullstack colombiano de 15 años</li>
              <li>Creador de LearnYos, APIs en NestJS y Spring Boot y dashboards con Tauri</li>
            </ul>
          </div>
          <div class="about-card">
            <h3>Enlaces</h3>
            <ul>
              <li><a href="https://github.com/xenoxf/Glenker" target="_blank" title="GitHub" rel="noopener noreferrer">GitHub</a></li>
              <li><a href="https://ko-fi.com/xenooxf" target="_blank" title="Apóyanos en Ko-fi" rel="noopener noreferrer">Apóyanos en Ko-fi</a></li>
              <li><a href="/#download">Descargar</a></li>
            </ul>
          </div>
        </aside>
      </div>
    </section>

    <Footer />
  </Shell>
</BaseLayout>

<style is:global>
.about-hero {
  position: relative;
  z-index: 1;
  padding: 4rem 2rem 2rem;
  text-align: center;
  max-width: 800px;
  margin: 0 auto;
}

.about-title {
  font-family: var(--font-heading);
  font-size: clamp(2.5rem, 5vw, 4rem);
  font-weight: 700;
  letter-spacing: -0.06em;
  line-height: 1.1;
  color: var(--text-primary);
  margin-bottom: 1.5rem;
}

.about-desc {
  font-size: 1.05rem;
  color: var(--text-secondary);
  line-height: 1.7;
  max-width: 640px;
  margin: 0 auto;
}

.about-content {
  position: relative;
  z-index: 1;
  padding: 2rem 2rem 5rem;
}

.about-grid {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 3rem;
  max-width: 1100px;
  margin: 0 auto;
}

.about-text h2 {
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: 1.5rem;
  letter-spacing: -0.04em;
  color: var(--text-primary);
  margin-top: 2rem;
  margin-bottom: 1rem;
}

.about-text p {
  color: var(--text-secondary);
  line-height: 1.7;
  margin-bottom: 1rem;
  font-size: 0.95rem;
}

.about-text ul {
  list-style: none;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.about-text ul li {
  padding-left: 1.5rem;
  position: relative;
  color: var(--text-secondary);
  font-size: 0.95rem;
  line-height: 1.6;
}

.about-text ul li::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0.6em;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--accent);
}

.about-text code {
  font-family: var(--font-mono);
  font-size: 0.85em;
  padding: 0.1em 0.4em;
  border-radius: 0.35rem;
  background: var(--accent-soft);
  color: var(--accent-text);
}

.about-sidebar {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.about-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: 1.5rem;
  transition: border-color var(--transition) var(--ease-out);
}

.about-card:hover {
  border-color: var(--accent);
}

.about-card h3 {
  font-family: var(--font-heading);
  font-weight: 600;
  font-size: 1rem;
  letter-spacing: -0.03em;
  color: var(--text-primary);
  margin-bottom: 1rem;
}

.about-card ul {
  list-style: none;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.about-card ul li {
  font-size: 0.85rem;
  color: var(--text-secondary);
  line-height: 1.6;
}

.about-card ul li strong {
  color: var(--text-primary);
}

.about-card a {
  color: var(--accent-active);
  transition: opacity 0.2s;
}

.about-card a:hover {
  text-decoration: underline;
}

@media (max-width: 900px) {
  .about-grid {
    grid-template-columns: 1fr;
  }
}
</style>
