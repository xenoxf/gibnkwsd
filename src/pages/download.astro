---
import BaseLayout from '../layouts/BaseLayout.astro';
import NoiseOverlay from '../components/ui/NoiseOverlay.astro';
import Shell from '../components/layout/Shell.astro';
import Navigation from '../components/layout/Navigation.astro';
import MobileMenu from '../components/layout/MobileMenu.astro';
import Download from '../components/sections/Download.astro';
import Footer from '../components/layout/Footer.astro';
import '../styles/shared.css';
import '../styles/responsive.css';
---

<BaseLayout
  title="Descargar Glenker — Interfaz para agentes de código AI"
  description="Descarga Glenker gratis para macOS, Windows y Linux, o úsalo desde la web y tu móvil. Interfaz para agentes de código con catálogo MCP, skills reutilizables y acceso remoto. Open source."
  canonical="https://glenker.vercel.app/download"
  keywords="descargar Glenker, agente de código, OpenCode, MCP, skills, macOS, Windows, Linux, web, PWA"
>
  <NoiseOverlay />
  <Navigation />
  <MobileMenu />
  <Shell>
    <section class="download-hero">
      <span class="section-label">// Descargar</span>
      <h1 class="download-hero-title">Descarga <span class="gradient-text">Glenker</span></h1>
      <p class="download-hero-desc">
        La interfaz visual para tus agentes de código. Escritorio, web y móvil,
        gratis y open source. Elige tu sistema y empieza en segundos.
      </p>
    </section>

    <Download />
    <Footer />
  </Shell>
</BaseLayout>

<style is:global>
.download-hero {
  position: relative;
  z-index: 1;
  padding: 4rem 2rem 0;
  text-align: center;
  max-width: 700px;
  margin: 0 auto;
}

.download-hero-title {
  font-family: var(--font-heading);
  font-size: clamp(2.5rem, 5vw, 4rem);
  font-weight: 700;
  letter-spacing: -0.06em;
  line-height: 1.1;
  color: var(--text-primary);
  margin-bottom: 1rem;
}

.download-hero-desc {
  font-size: 1.05rem;
  color: var(--text-secondary);
  line-height: 1.7;
}
</style>
