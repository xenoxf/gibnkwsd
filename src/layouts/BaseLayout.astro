---
import '../styles/variables.css';
import '../styles/reset.css';
import '../styles/animations.css';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  keywords?: string;
  ogImage?: string;
}

const { title, description, canonical, keywords, ogImage } = Astro.props;
const site = 'https://glenker.vercel.app';
const defaultOgImage = ogImage || '/og-image.png';
const pageTitle = title;
const pageCanonical = canonical || `${site}${Astro.url.pathname}`;
const pageKeywords = keywords || 'asistente de IA, inteligencia artificial, AI code agent, desarrolladores, Glenker';
const pageDescription = description;
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="google-site-verification" content="bUWA640cYC5xTz1CRqp5SlH2r6aH8-E_nhgSWgb3T9I" />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="Glenker" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#ccff00" />
    <link rel="canonical" href={canonical || `${site}${Astro.url.pathname}`} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={`${site}${defaultOgImage}`} />
    <meta property="og:url" content={canonical || `${site}${Astro.url.pathname}`} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Glenker" />
    <meta property="og:locale" content="es_ES" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={`${site}${defaultOgImage}`} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Glenker",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "macOS, Windows, Linux",
      "description": "Glenker es un asistente de inteligencia artificial para cualquier persona. Catálogo MCP, 1000+ integraciones con servicios, skills reutilizables.",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "author": {
        "@type": "Organization",
        "name": "Glenker"
      }
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Glenker",
      "url": site,
      "description": "Glenker es un asistente de inteligencia artificial para cualquier persona. Catálogo MCP, 1000+ integraciones con servicios, skills reutilizables.",
      "foundingDate": "2025",
      "sameAs": [
        "https://discord.gg/ZYRSdnwwKA"
      ]
    })} />
  </head>
  <body>
    <slot />
    <script src="/download.js" defer></script>
  </body>
</html>
